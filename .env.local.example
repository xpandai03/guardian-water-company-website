# Copy this file to `.env.local` (gitignored) and fill in values.
# In Vercel, add each variable to BOTH "Production" and "Preview" scopes.

# ---------- Jobber ----------
# From Jobber Developer Center → your app → "Client ID"
JOBBER_CLIENT_ID=

# From Jobber Developer Center → your app → "Client Secret". Server-only.
JOBBER_CLIENT_SECRET=

# Exact callback URL registered in the Jobber app config. Must match
# Vercel deployment URL (production domain). Example:
#   https://guardianwater.com/api/jobber/oauth/callback
JOBBER_REDIRECT_URI=

# Long-lived refresh token. Empty until the one-time OAuth handshake
# completes — see README "Lead intake integration".
# Refresh-token rotation is OFF (BACKEND_PLAN.md §4) so this value is stable
# until the Jobber app is re-authorized.
JOBBER_REFRESH_TOKEN=

# Pinned Jobber GraphQL API version. Set to the version you validated in
# GraphiQL (Jobber Developer Center → "Test in GraphiQL"). Falls back to a
# default in lib/jobber/config.ts if unset, but a pinned value is safer.
JOBBER_GRAPHQL_VERSION=

# ---------- Twilio ----------
# Twilio Console → Account → Account SID
TWILIO_ACCOUNT_SID=

# Twilio Console → Account → Auth Token. Server-only.
TWILIO_AUTH_TOKEN=

# SMS-capable Twilio phone number in E.164 format, e.g. +12165550199
TWILIO_FROM_NUMBER=

# Optional: override the SMS body. `{firstName}` is the only template variable.
# If unset, falls back to BACKEND_PLAN.md §7 Candidate A.
LEAD_CONFIRMATION_SMS_TEMPLATE=
